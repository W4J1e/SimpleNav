# Azure OAuth 配置
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# JWT 密钥
JWT_SECRET=your_jwt_secret_key

# 可选：自定义回调URL（如果不设置，将根据环境自动生成）
# AZURE_REDIRECT_URI=http://localhost:3000/api/auth/callback  # 开发环境
# AZURE_REDIRECT_URI=https://a.hin.cool/api/auth/callback  # 生产环境